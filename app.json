{
  "expo": {
    "name": "Johanan-Choir-Application",
    "slug": "Johanan-Choir-Application",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Johanan-Choir-Application.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Johanan-Choir-Application.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Johanan-Choir-Application.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.peniel93abebe.JohananChoirApplication"
    },
    "web": {
      "favicon": "./assets/Johanan-Choir-Application.png"
    },
    "extra": {
      "eas": {
        "projectId": "9c782125-6e8c-4dd5-bc75-9add1913188f"
      }
    },
    "owner": "peniel93abe",
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ]
    ]
  }
}
